<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tafilalt Store</title>
<link rel="stylesheet" href="style.css">
</head>

<body>

<header>
<h1>Tafilalt Store</h1>
<p>📍 Ain El Aouda - Al Hayat | 📞 0754569436</p>
</header>

<nav>
<button onclick="showSection('home')">Accueil | الرئيسية</button>
<button onclick="showSection('products')">Produits</button>
<button onclick="showSection('cart')">Panier 🛒</button>
<button onclick="showSection('contact')">Contact</button>
</nav>

<!-- HOME -->
<section id="home" class="active">
<h2>Bienvenue | مرحبا بكم</h2>
<p>Meilleure qualité - Livraison rapide - Paiement à la livraison</p>
<a class="btn" href="https://wa.me/212754569436">WhatsApp 📲</a>
</section>

<!-- PRODUCTS -->
<section id="products">
<h2>Produits</h2>

<div class="card">
<p>Dattes Medjool - 80 DH</p>
<button onclick="addToCart('Dattes Medjool',80)">Ajouter</button>
</div>

<div class="card">
<p>Lentilles - 18 DH</p>
<button onclick="addToCart('Lentilles',18)">Ajouter</button>
</div>

<div class="card">
<p>Huile d'Olive - 75 DH</p>
<button onclick="addToCart('Huile d\'Olive',75)">Ajouter</button>
</div>

</section>

<!-- CART -->
<section id="cart">
<h2>Panier 🛒</h2>
<ul id="cartList"></ul>
<p id="total">Total: 0 DH</p>

<button onclick="sendOrder()">Commander maintenant</button>
</section>

<!-- CONTACT -->
<section id="contact">
<h2>Contact</h2>
<p>Email: tafilaltstores1@gmail.com</p>
<p>Tel: 0754569436</p>
<p>Paiement à la livraison</p>
</section>

<script src="script.js"></script>
</body>
</html>body{
font-family:Arial;
margin:0;
background:#f5f7ff;
}

header{
background:#0066cc;
color:white;
text-align:center;
padding:20px;
}

nav{
display:flex;
justify-content:center;
background:#004c99;
flex-wrap:wrap;
}

nav button{
background:none;
border:none;
color:white;
padding:15px;
cursor:pointer;
}

section{
display:none;
padding:20px;
}

section.active{
display:block;
}

.card{
background:white;
padding:15px;
margin:10px 0;
border-radius:10px;
}

.btn{
display:inline-block;
padding:10px;
background:#25D366;
color:white;
text-decoration:none;
border-radius:5px;
}
